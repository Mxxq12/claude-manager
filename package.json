{
  "name": "claude-manager",
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "npm run electron:dev",
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "electron:dev": "tsc -p tsconfig.node.json && electron dist-electron/main.js",
    "build:dmg": "electron-builder --mac --config electron-builder.json -c.mac.identity=null",
    "build:all": "npm run build && npm run build:dmg",
    "clean": "rm -rf dist dist-electron release *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "bcryptjs": "^3.0.3",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vitest": "^3.2.4"
  }
}
